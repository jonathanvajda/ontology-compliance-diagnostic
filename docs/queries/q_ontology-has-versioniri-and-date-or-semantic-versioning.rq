PREFIX owl: <http://www.w3.org/2002/07/owl#>

SELECT DISTINCT ?ont ?versionIRI
WHERE {
  ?ont a owl:Ontology ;
       owl:versionIRI ?versionIRI .

  BIND(STR(?versionIRI) AS ?v)

  FILTER(
    REGEX(
      ?v,
      "(^|[/#])([0-9]{4}-[0-9]{2}-[0-9]{2})([/#]|$)"
    )
    ||
    REGEX(
      ?v,
      "(^|[/#])v?[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.-]+)?(\\+[A-Za-z0-9.-]+)?([/#]|$)"
    )
  )
}
ORDER BY ?ont ?versionIRI