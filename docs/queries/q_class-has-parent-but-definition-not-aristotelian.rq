# q_class-has-parent-but-definition-not-aristotelian
# SPARQL query to find class whose parent's label isn't the named genus in the class's textual definition

PREFIX owl:  <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX obo:  <http://purl.obolibrary.org/obo/>

SELECT ?resource ?termLabel ?def
       (GROUP_CONCAT(DISTINCT ?parentLabel; separator=" | ") AS ?candidateParents)
WHERE {
  ?resource a owl:Class ;
        rdfs:subClassOf ?parent ;
        ?defProp ?def .

  VALUES ?defProp { obo:IAO_0000115 skos:definition }

  FILTER(isIRI(?parent))
  ?parent rdfs:label ?parentLabel .
  OPTIONAL { ?resource rdfs:label ?termLabel }

  FILTER(LANG(?def) = "" || LANGMATCHES(LANG(?def), "en"))
  FILTER(LANG(?parentLabel) = "" || LANGMATCHES(LANG(?parentLabel), "en"))

  BIND(REPLACE(LCASE(STR(?def)), "[^a-z0-9 ]", " ") AS ?def1)
  BIND(REPLACE(?def1, "\\s+", " ") AS ?defNorm)

  BIND(REPLACE(LCASE(STR(?parentLabel)), "[^a-z0-9 ]", " ") AS ?parent1)
  BIND(REPLACE(?parent1, "\\s+", " ") AS ?parentNorm)

  BIND(
    IF(
      REGEX(
        ?defNorm,
        CONCAT(
          "^\\s*(a|an)\\s+",
          ?parentNorm,
          "\\s+((that|which|who|where|with|having|bearing|inhering|located|derived|used|composed|characterized)\\b|[a-z]+ing\\b)"
        )
      ),
      1,
      0
    ) AS ?looksAristotelian
  )
}
GROUP BY ?resource ?termLabel ?def
HAVING(MAX(?looksAristotelian) = 0)
ORDER BY LCASE(STR(COALESCE(?termLabel, STR(?resource))))