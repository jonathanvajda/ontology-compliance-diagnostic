PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT DISTINCT ?ont ?license
WHERE {
  ?ont a owl:Ontology ;
       dcterms:license ?license .

  BIND(LCASE(STR(?license)) AS ?lic)

  FILTER(
    (
      isIRI(?license) &&
      REGEX(?lic, "^https?://creativecommons\\.org/licenses/by/([0-9]+(\\.[0-9]+)?)/?$") &&
      xsd:decimal(
        REPLACE(
          ?lic,
          "^https?://creativecommons\\.org/licenses/by/([0-9]+(\\.[0-9]+)?)/?$",
          "$1"
        )
      ) >= 3.0
    )
    ||
    (
      isIRI(?license) &&
      REGEX(?lic, "^https?://creativecommons\\.org/publicdomain/zero/1\\.0/?$")
    )
  )
}
ORDER BY ?ont ?license