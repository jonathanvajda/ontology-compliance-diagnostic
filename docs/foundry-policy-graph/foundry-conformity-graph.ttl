@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .

@prefix obo:  <http://purl.obolibrary.org/obo/> .
@prefix okea: <https://github.com/jonathanvajda/okea/> .
@prefix cco:  <https://www.commoncoreontologies.org/> .

##########
# TBox
##########

okea:has_specification_criterion
    rdf:type owl:ObjectProperty ;
    rdfs:label "has specification criterion" .

okea:has_formalization
    rdf:type owl:ObjectProperty ;
    rdfs:label "has formalization" .
    

cco:ont00000965
    rdf:type owl:Class ;
    rdfs:label "Directive Information Content Entity" .

obo:OBI_0500026
    rdf:type owl:Class ;
    rdfs:label "Eligibility Criterion" .

okea:SPARQLQuery
    rdf:type owl:Class ;
    rdfs:label "SPARQL Query" .

okea:SpecificationRequirement
    rdf:type owl:Class ;
    rdfs:label "Specification Requirement" .

okea:SpecificationRecommendation
    rdf:type owl:Class ;
    rdfs:label "Specification Recommendation" .

##########
# ABox
##########

okea:OntologyFoundryPolicy
    rdf:type owl:NamedIndividual ;
    rdf:type cco:ont00000965 ;
    rdfs:label "Ontology Foundry Policy" ;
    obo:BFO_0000178 okea:OntologyFoundryPolicy_requirement_v10_req_0001 ;
    obo:BFO_0000178 okea:OntologyFoundryPolicy_requirement_v10_req_0002 ;
    obo:BFO_0000178 okea:OntologyFoundryPolicy_requirement_v10_rec_0001 .

okea:OntologyFoundryPolicy_requirement_v10_req_0001
    rdf:type owl:NamedIndividual ;
    rdf:type okea:SpecificationRequirement ;
    rdfs:label "Ontology Foundry v0.1.0 req0001" ;
    okea:has_specification_criterion okea:Criterion_ClassHasRdfsLabel .

okea:Criterion_ClassHasRdfsLabel
    rdf:type owl:NamedIndividual ;
    rdf:type obo:OBI_0500026 ;
    rdfs:label "Criterion Class Has RDFS Label" ;
    okea:has_formalization okea:SPARQLQuery_ClassMissingRdfsLabel .

okea:SPARQLQuery_ClassMissingRdfsLabel
    rdf:type owl:NamedIndividual ;
    rdf:type okea:SPARQLQuery ;
    rdfs:label "SPARQL Query Class Missing Rdfs Label" .

okea:OntologyFoundryPolicy_requirement_v10_rec_0001
    rdf:type owl:NamedIndividual ;
    rdf:type okea:SpecificationRecommendation ;
    rdfs:label "Ontology Foundry v0.1.0 rec0001" ;
    okea:has_specification_criterion okea:Criterion_ClassHasSkosExample .

okea:Criterion_ClassHasSkosExample
    rdf:type owl:NamedIndividual ;
    rdf:type obo:OBI_0500026 ;
    rdfs:label "Criterion Class Has SKOS Example" ;
    okea:has_formalization okea:SPARQLQuery_ClassMissingSkosExample .

okea:SPARQLQuery_ClassMissingSkosExample
    rdf:type owl:NamedIndividual ;
    rdf:type okea:SPARQLQuery ;
    rdfs:label "SPARQL Query Class Missing SKOS Example" .

okea:OntologyFoundryPolicy_requirement_v10_req_0002
    rdf:type owl:NamedIndividual ;
    rdf:type okea:SpecificationRequirement ;
    rdfs:label "Ontology Foundry v0.1.0 req0002" ;
    okea:has_specification_criterion okea:Criterion_ClassHasSkosDefinition .

okea:Criterion_ClassHasSkosDefinition
    rdf:type owl:NamedIndividual ;
    rdf:type obo:OBI_0500026 ;
    rdfs:label "Criterion Class Has SKOS Definition" ;
    okea:has_formalization okea:SPARQLQuery_ClassMissingSkosDefinition .

okea:SPARQLQuery_ClassMissingSkosDefinition
    rdf:type owl:NamedIndividual ;
    rdf:type okea:SPARQLQuery ;
    rdfs:label "SPARQL Query Class Missing SKOS Definition" .